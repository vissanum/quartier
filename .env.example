# Google Places API (New) — required for prospecting and business data
# Get yours at: https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" in your project
# Free tier: 5,000 requests/month
GOOGLE_PLACES_API_KEY=your-api-key-here

# Resend — required for client outreach emails (outreach/send.js)
# Get yours at: https://resend.com/api-keys
# Verify your sending domain (SPF/DKIM) to send beyond your own address
RESEND_API_KEY=your-resend-api-key
